# Copy this file to .env — it is gitignored.
# All services read their config from environment variables sourced from .env.

# PostgreSQL / TimescaleDB
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline
POSTGRES_DB=marketdata

# Grafana
GRAFANA_ADMIN_PASSWORD=admin

# Redpanda
# Internal (container-to-container) address — do not change unless you
# rename the redpanda service in docker-compose.yml.
REDPANDA_BROKERS=redpanda:9092

# Data ingestion
# Kraken trading pair. Must match Kraken's symbol format exactly.
SYMBOL=BTC/USD
